typeset -g POWERLEVEL9K_PER_DIRECTORY_HISTORY_GLOBAL_BACKGROUND=${yellow}

# cpu_arch
typeset -g POWERLEVEL9K_CPU_ARCH_FOREGROUND=${black}
typeset -g POWERLEVEL9K_CPU_ARCH_BACKGROUND=${yellow}

function prompt_example() {
  p10k segment -b 1 -f 3 -i '‚≠ê' -t 'hello, %n'
}

function instant_prompt_example() {
  prompt_example
}

typeset -g POWERLEVEL9K_EXAMPLE_FOREGROUND=${yellow}
typeset -g POWERLEVEL9K_EXAMPLE_BACKGROUND=${red}

typeset -g POWERLEVEL9K_TRANSIENT_PROMPT=always
typeset -g POWERLEVEL9K_INSTANT_PROMPT=verbose
typeset -g POWERLEVEL9K_DISABLE_HOT_RELOAD=true

(( ! $+functions[p10k] )) || p10k reload

typeset -g POWERLEVEL9K_CONFIG_FILE=\${(%):-%x}

(( \${+p10k_config_opts} )) && setopt \${p10k_config_opts[@]}
'builtin' 'unset' 'p10k_config_opts'
";
}
